{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "smart-types": ["../smart-types/index.js"],
      "smart-types/*": ["../smart-types/*"],
      "smart-utils/*": ["../smart-utils/*"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./main.js",
    "./collection.js",
    "./item.js",
    "./adapters/**/*.js",
    "./utils/**/*.js"
  ],
  "exclude": [
    "./tests/**/*.js",
    "./**/*.test.js",
    "./node_modules/**"
  ]
}
